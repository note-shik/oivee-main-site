# Supabase — lead storage (primary, blocking)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# SMTP — owner notification + auto-reply (free path: Gmail App Password)
# Setup: enable 2FA on Google account → https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.address@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="Oivee <support@oivee.com>"
OWNER_EMAIL=support@oivee.com

# Upstash Redis — rate limiting (free tier; falls back to allow-all if unset)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_rest_token

# n8n — DEPRECATED, kept as fallback only. Leave unset to disable.
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/lead

# WhatsApp business number (displayed on site)
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Analytics (optional — script tags only render when set)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=your_pixel_id

# Site URL (for OG tags + sitemap)
NEXT_PUBLIC_SITE_URL=https://oivee.com
