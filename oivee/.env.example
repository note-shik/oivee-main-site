# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=your_pixel_id

# Site URL (for OG tags)
NEXT_PUBLIC_SITE_URL=https://oivee.in
